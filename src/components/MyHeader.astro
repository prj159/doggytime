---
// ═══════════════════════════════════════════════════════════════
//  🛠️  可修改区域：数据 & 组件引用
//  - SITE_TITLE: 站点标题，修改 ../consts.ts 中的值
//  - HeaderLink: 导航链接组件，见 ./HeaderLink.astro
// ═══════════════════════════════════════════════════════════════
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const homeHref = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
---

<!--
  ═══════════════════════════════════════════════════════════════
  🛠️  可修改区域：页面结构 (HTML)
  ═══════════════════════════════════════════════════════════════
-->
<header>
	<nav>
		<!-- 🛠️ 站点标题 — 文字来自 ../consts.ts 的 SITE_TITLE，链接指向 '/' -->
		<h2 class="site-title">
			<a class="site-title-link" href={homeHref}>
				<!-- 第一步：默认显示站点标题文字；hover 时由 .title-text 做淡出/上移动画。 -->
				<span class="title-text">{SITE_TITLE}</span>
				<!-- 第二步：房子图标层；动画加在外层 span 上，SVG 本体保持静态绘制，避免线条抖动。 -->
				<span class="title-hover" aria-hidden="true">
					<svg
						class="title-icon lucide lucide-house-icon lucide-house"
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						focusable="false"
					>
						<path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8" />
						<path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
					</svg>
				</span>
			</a>
		</h2>

		<!--
		  🛠️ 导航链接 — 增删 <HeaderLink> 即可调整导航条目
		  href: 页面路径  |  标签内容: 显示文字
		  HeaderLink 组件自带 active 高亮逻辑，见 ./HeaderLink.astro
		-->
		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/blog">Blog</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>

		<!--
		  🛠️ 社交图标 — 替换 href 为你的链接，替换 <svg> 为你的图标
		  width/height: 图标尺寸 (32x32)
		  .sr-only span: 无障碍描述文字
		-->
		<div class="social-links">
			<a href="https://m.webtoo.ls/@astro" target="_blank">
				<span class="sr-only">Follow Astro on Mastodon</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M11.19 12.195c2.016-.24 3.77-1.475 3.99-2.603.348-1.778.32-4.339.32-4.339 0-3.47-2.286-4.488-2.286-4.488C12.062.238 10.083.017 8.027 0h-.05C5.92.017 3.942.238 2.79.765c0 0-2.285 1.017-2.285 4.488l-.002.662c-.004.64-.007 1.35.011 2.091.083 3.394.626 6.74 3.78 7.57 1.454.383 2.703.463 3.709.408 1.823-.1 2.847-.647 2.847-.647l-.06-1.317s-1.303.41-2.767.36c-1.45-.05-2.98-.156-3.215-1.928a3.614 3.614 0 0 1-.033-.496s1.424.346 3.228.428c1.103.05 2.137-.064 3.188-.189zm1.613-2.47H11.13v-4.08c0-.859-.364-1.295-1.091-1.295-.804 0-1.207.517-1.207 1.541v2.233H7.168V5.89c0-1.024-.403-1.541-1.207-1.541-.727 0-1.091.436-1.091 1.296v4.079H3.197V5.522c0-.859.22-1.541.66-2.046.456-.505 1.052-.764 1.793-.764.856 0 1.504.328 1.933.983L8 4.39l.417-.695c.429-.655 1.077-.983 1.934-.983.74 0 1.336.259 1.791.764.442.505.661 1.187.661 2.046v4.203z"
					></path></svg
				>
			</a>
			<a href="https://twitter.com/astrodotbuild" target="_blank">
				<span class="sr-only">Follow Astro on Twitter</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"
					></path></svg
				>
			</a>
			<a href="https://github.com/withastro/astro" target="_blank">
				<span class="sr-only">Go to Astro's GitHub repo</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>

<style>
	/* 站点标题 */
	.site-title {
		/* Average Sans 已在 astro.config.mjs 注册并由 BaseHead.astro 预加载。 */
		font-family: var(--font-average-sans);
		font-size: larger; /* 可改：站点标题字体大小。 */
		letter-spacing: 0.02em; /* 可改：字距；正数更疏，负数更紧 */
		font-weight: 500; /* 可改：400 为正常粗细，避免 h2 默认粗体 */
	}

	/* 标题链接作为文字层和房子图标层的共同定位容器。 */
	.site-title-link {
			position: relative;
			display: inline-block;
			color: rgb(var(--black));
			text-decoration: none;
			white-space: nowrap;
			isolation: isolate;
			transform: translate3d(0, 0, 0);
		}

		/* 默认文字层决定链接尺寸，悬停时只使用 transform 和 opacity 离场。 */
		.title-text {
			display: block;
			transform-origin: center;
			backface-visibility: hidden;
			pointer-events: none;
			will-change: transform, opacity;
			/* 可改：0.14s 控制文字离场动画时长。 */
			transition:
				transform 0.14s cubic-bezier(0.34, 1.56, 0.64, 1),
				opacity 0.14s ease;
		}

		/* 房子图标层覆盖在文字中心，初始隐藏在下方并缩小。 */
		.title-hover {
			position: absolute;
			inset: 0;
			display: grid;
			place-items: center;
			width: 1.0em; /* 可改：房子图标宽度。 */
			height: 1.0em; /* 可改：房子图标高度。 */
			margin: auto;
			opacity: 0;
			pointer-events: none;
			transform: translate3d(0, 7px, 0) scale(0.4);
			transform-origin: center;
			backface-visibility: hidden;
			will-change: transform, opacity;
			/* 可改：0.14s 控制图标弹入动画时长。 */
			transition:
				transform 0.14s cubic-bezier(0.34, 1.56, 0.64, 1),
				opacity 0.14s ease;
		}

		/* SVG 只负责绘制图标，动画放在外层，避免缩放描边时产生抖动。 */
		.title-icon {
			display: block;
			width: 100%;
			height: 100%;
			overflow: visible;
			shape-rendering: geometricPrecision;
		}

		/* 鼠标悬停或键盘聚焦时：文字上移淡出，房子图标弹入。 */
		.site-title-link:hover .title-text,
		.site-title-link:focus-visible .title-text {
			opacity: 0;
			transform: translate3d(0, -5px, 0) scale(0.9);
		}

		.site-title-link:hover .title-hover,
		.site-title-link:focus-visible .title-hover {
			opacity: 1;
			transform: translate3d(0, 0, 0) scale(1);
		}

		/* 固定在页面顶部的 header 容器。 */
		header {
			margin: 0;
			padding: 0 1em;
			position: fixed;
			top: 0;
			left: 0;
			right: 0;
			z-index: 50;
			min-height: 64px; /* 可改：header 最小高度。 */
			/* 可选：需要透明背景、阴影或毛玻璃时取消对应属性的注释。 */
			/* background: rgba(255, 255, 255, 0); */
			/* box-shadow: 0 2px 8px rgba(var(--black), 5%); */
			/* backdrop-filter: blur(14px); */
			/* -webkit-backdrop-filter: blur(14px); */
		}

		/* 导航栏使用 Flex 将站点标题、内部链接和社交链接横向排列。 */
		nav {
			position: relative;
			z-index: 2;
			display: flex;
			align-items: center;
			justify-content: space-between;
			min-height: 64px; /* 可改：导航栏最小高度，通常与 header 保持一致。 */
		}

		/* 清除站点标题 h2 的默认外边距。 */
		h2 {
			margin: 0;
			font-size: 1em;
		}

		/* 标题链接不显示普通链接下划线。 */
		h2 a,
		h2 a.active {
			text-decoration: none;
		}

		/* 可改：导航链接的内边距、颜色与底部指示线。 */
		nav a {
			padding: 1em 0.5em;
			color: rgb(var(--black));
			border-bottom: 4px solid transparent;
			text-decoration: none;
		}

		/* 当前页面的导航链接显示强调色底线。 */
		nav a.active {
			text-decoration: none;
			border-bottom-color: var(--accent);
		}

		/* 社交链接及其点击区域使用 Flex 布局。 */
		.social-links,
		.social-links a {
			display: flex;
		}

		/* 可改：视口不超过 720px 时隐藏社交链接。 */
		@media (max-width: 720px) {
			.social-links {
				display: none;
			}
		}

</style>
