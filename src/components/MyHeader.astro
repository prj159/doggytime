---
// ═══════════════════════════════════════════════════════════════
//  🛠️  可修改区域：数据 & 组件引用
//  - SITE_TITLE: 站点标题，修改 ../consts.ts 中的值
//  - HeaderLink: 导航链接组件，见 ./HeaderLink.astro
// ═══════════════════════════════════════════════════════════════
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const homeHref = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
---

<!--
  ═══════════════════════════════════════════════════════════════
  🛠️  可修改区域：页面结构 (HTML)
  ═══════════════════════════════════════════════════════════════
-->
<header>
	<nav>
		<!-- 🛠️ 站点标题 — 文字来自 ../consts.ts 的 SITE_TITLE，链接指向 '/' -->
		<h2 class="site-title">
			<a class="site-title-link" href={homeHref}>
				<!-- 第一步：默认显示站点标题文字；hover 时由 .title-text 做淡出/上移动画。 -->
				<span class="title-text">{SITE_TITLE}</span>
				<!-- 第二步：房子图标层；动画加在外层 span 上，SVG 本体保持静态绘制，避免线条抖动。 -->
				<span class="title-hover" aria-hidden="true">
					<svg
						class="title-icon lucide lucide-house-icon lucide-house"
						xmlns="http://www.w3.org/2000/svg"
						width="24"
						height="24"
						viewBox="0 0 24 24"
						fill="none"
						stroke="currentColor"
						stroke-width="2"
						stroke-linecap="round"
						stroke-linejoin="round"
						focusable="false"
					>
						<path d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8" />
						<path d="M3 10a2 2 0 0 1 .709-1.528l7-6a2 2 0 0 1 2.582 0l7 6A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
					</svg>
				</span>
			</a>
		</h2>

		<!--
		  🛠️ 导航链接 — 增删 <HeaderLink> 即可调整导航条目
		  href: 页面路径  |  标签内容: 显示文字
		  HeaderLink 组件自带 active 高亮逻辑，见 ./HeaderLink.astro
		-->
		<div class="internal-links">
			<HeaderLink class="nav-link" href="/blog">Blog</HeaderLink>
			<span class="nav-separator" aria-hidden="true">/</span>
			<HeaderLink class="nav-link" href="https://github.com/prj159">About</HeaderLink>
		</div>
	</nav>
</header>

<style>
	/* 站点标题 */
	.site-title {
		/* Average Sans 已在 astro.config.mjs 注册并由 BaseHead.astro 预加载。 */
		font-family: var(--font-average-sans);
		font-size: larger; /* 可改：站点标题字体大小。 */
		letter-spacing: 0.02em; /* 可改：字距；正数更疏，负数更紧 */
		font-weight: 500; /* 可改：400 为正常粗细，避免 h2 默认粗体 */
	}

	/* 标题链接作为文字层和房子图标层的共同定位容器。 */
	.site-title-link {
			position: relative;
			display: inline-block;
			color: rgb(var(--black));
			text-decoration: none;
			white-space: nowrap;
			isolation: isolate;
			transform: translate3d(0, 0, 0);
		}

		/* 默认文字层决定链接尺寸，悬停时只使用 transform 和 opacity 离场。 */
		.title-text {
			display: block;
			transform-origin: center;
			backface-visibility: hidden;
			pointer-events: none;
			will-change: transform, opacity;
			/* 可改：0.14s 控制文字离场动画时长。 */
			transition:
				transform 0.14s cubic-bezier(0.34, 1.56, 0.64, 1),
				opacity 0.14s ease;
		}

		/* 房子图标层覆盖在文字中心，初始隐藏在下方并缩小。 */
		.title-hover {
			position: absolute;
			inset: 0;
			display: grid;
			place-items: center;
			width: 1.0em; /* 可改：房子图标宽度。 */
			height: 1.0em; /* 可改：房子图标高度。 */
			margin: auto;
			opacity: 0;
			pointer-events: none;
			transform: translate3d(0, 7px, 0) scale(0.4);
			transform-origin: center;
			backface-visibility: hidden;
			will-change: transform, opacity;
			/* 可改：0.14s 控制图标弹入动画时长。 */
			transition:
				transform 0.14s cubic-bezier(0.34, 1.56, 0.64, 1),
				opacity 0.14s ease;
		}

		/* SVG 只负责绘制图标，动画放在外层，避免缩放描边时产生抖动。 */
		.title-icon {
			display: block;
			width: 100%;
			height: 100%;
			overflow: visible;
			shape-rendering: geometricPrecision;
		}

		/* 鼠标悬停或键盘聚焦时：文字上移淡出，房子图标弹入。 */
		.site-title-link:hover .title-text,
		.site-title-link:focus-visible .title-text {
			opacity: 0;
			transform: translate3d(0, -5px, 0) scale(0.9);
		}

		.site-title-link:hover .title-hover,
		.site-title-link:focus-visible .title-hover {
			opacity: 1;
			transform: translate3d(0, 0, 0) scale(1);
		}

		/* 固定在页面顶部的 header 容器。 */
		header {
			margin: 0;
			padding: 0 1em;
			position: fixed;
			top: 0;
			left: 0;
			right: 0;
			z-index: 50;
			min-height: 64px; /* 可改：header 最小高度。 */
			/* 可选：需要透明背景、阴影或毛玻璃时取消对应属性的注释。 */
			/* background: rgba(255, 255, 255, 0); */
			/* box-shadow: 0 2px 8px rgba(var(--black), 5%); */
			/* backdrop-filter: blur(14px); */
			/* -webkit-backdrop-filter: blur(14px); */
		}

		/* 导航栏使用 Flex 将站点标题和内部链接分列在左右两侧。 */
		nav {
			position: relative;
			z-index: 2;
			display: flex;
			align-items: center;
			justify-content: space-between;
			min-height: 64px; /* 可改：导航栏最小高度，通常与 header 保持一致。 */
		}

		/* 清除站点标题 h2 的默认外边距。 */
		h2 {
			margin: 0;
			font-size: 1em;
		}

		/* 标题链接不显示普通链接下划线。 */
		h2 a,
			h2 a.active {
			text-decoration: none;
		}

		/* Blog / About 导航区：横向排列，并统一使用 Average Sans。 */
		.internal-links {
			display: flex;
			flex-direction: row;
			align-items: center;
			gap: 0.5rem; /* 可改：链接与斜杠之间的距离。 */
			color: #454545;
			font-family: var(--font-average-sans), Arial, sans-serif;
			font-style: italic;
			font-size:20px; /* 与站点标题保持相同大小。 */
			font-weight: 400; /* 可改：导航链接字体粗细。 */
			position: relative;
			left: 0rem; /* 可改：正值向右、负值向左。 */
			top: 0rem; /* 可改：正值向下、负值向上。 */
		}

		/* HeaderLink 内部的 a 使用上方导航区设置的字体参数。 */
		.internal-links :global(.nav-link) {
			font-family: inherit;
			font-size: inherit;
			font-weight: inherit;
			position: relative;
		}

		.nav-separator {
			user-select: none;
		}

		/* 可改：导航链接的内边距、颜色与底部指示线。 */
		nav a {
			padding: 1em 0.5em;
			color: rgb(var(--black));
			border-bottom: 4px solid transparent;
			text-decoration: none;
		}

		/* 当前页面的导航链接显示强调色底线。 */
		nav a.active {
			text-decoration: none;
			border-bottom-color: var(--accent);
		}

		/* 导航链接使用动画下划线，因此隐藏当前页面原有的常驻底边。 */
		.internal-links :global(.nav-link.active) {
			border-bottom-color: transparent;
		}

		/* 下划线的位置、长度、粗细和动画速度都可以在这里调整。 */
		.internal-links :global(.nav-link)::after {
			content: '';
			position: absolute;
			left: 0.5em; /* 可改：线条左端位置；数值越大，左端越向右。 */
			right: 0.5em; /* 可改：线条右端位置；数值越大，右端越向左。 */
			bottom: 1.0em; /* 可改：线条上下位置；数值越大越向上，越小越向下。 */
			height: 1px; /* 可改：线条粗细。 */
			background-color: currentColor; /* 线条自动使用与文字相同的颜色。 */
			pointer-events: none;
			transform: scaleX(0);
			transform-origin: right center; /* 鼠标移走时，线条向右收起。 */
			transition: transform 0.28s ease; /* 可改：0.28s 是动画持续时间。 */
			will-change: transform;
		}

		.internal-links :global(.nav-link:hover)::after,
		.internal-links :global(.nav-link:focus-visible)::after {
			transform: scaleX(1);
			transform-origin: left center; /* 鼠标移入时，线条从左向右展开。 */
		}

</style>
